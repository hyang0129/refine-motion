# --- required ---
# A GitHub Personal Access Token with `repo` scope (or `public_repo` for public repos).
# Used to create / update issues on the target repository.
GITHUB_TOKEN=ghp_replace_me

# --- optional ---
# Path to the Claude CLI. If not set, defaults to `claude` on PATH.
# CLAUDE_CLI=/usr/local/bin/claude

# Whisper model size for local STT. Smaller = faster, less accurate.
# Options: tiny.en | base.en | small.en | medium.en
WHISPER_MODEL=base.en

# Where Whisper caches downloaded model weights.
# Default: ~/.cache/huggingface/hub
# WHISPER_CACHE_DIR=

# Bind address / port for the local server.
HOST=127.0.0.1
PORT=8000
